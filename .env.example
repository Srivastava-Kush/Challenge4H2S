# ─── MongoDB ──────────────────────────────────────────────────────────────────
# For local dev use the default below. For Render / production, use a MongoDB Atlas URI.
MONGO_URI=mongodb://localhost:27017/stadiumiq

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=stadiumiq_jwt_secret_2026_worldcup

# ─── Hugging Face AI (required for chatbot LLM + embeddings) ──────────────────
# Get your free token from https://huggingface.co/settings/tokens
HF_TOKEN=your-huggingface-token-here

# Open-source model names (defaults used if not set)
CHAT_MODEL=Qwen/Qwen2.5-72B-Instruct
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2

# ─── MongoDB Atlas Vector Search ──────────────────────────────────────────────
# Name of the Atlas Vector Search index on the StadiumDoc collection
VECTOR_INDEX_NAME=stadium_docs

# ─── Firebase (optional — for Google sign-in) ─────────────────────────────────
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:000000000000

# ─── Razorpay (optional — for food ordering) ──────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_SECRET=your_razorpay_secret
